# Copie ce fichier en .env (jamais commité) et renseigne une valeur secrète.
# Génère-en une avec : openssl rand -base64 64
JWT_SECRET=

# Envoi d'email réel (confirmation de compte, mot de passe oublié, invitations).
# Laisser MAIL_ENABLED à false pour désactiver l'envoi (les emails sont alors
# simplement loggés). Avec Gmail, MAIL_USERNAME est ton adresse et MAIL_PASSWORD
# un mot de passe d'application (https://myaccount.google.com/apppasswords),
# jamais ton mot de passe Gmail habituel.
MAIL_ENABLED=false
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=
FRONTEND_URL=http://localhost:4200
